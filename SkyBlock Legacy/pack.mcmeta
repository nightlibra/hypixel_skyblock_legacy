{
  "pack": {
    "min_format": [75, 0],
    "max_format": [88, 0],
    "description": ["The original Hypixel SkyBlock textures",{"text":" -nightlibra","color":"dark_gray"}]
  },

  "overlays": {
    "entries": [
      {
        "directory": "mc-1_21_11",
        "min_format": [75, 0],
        "max_format": [75, 0]
      },
      {
        "directory": "mc-26_1",
        "min_format": [84, 0],
        "max_format": [84, 0]
      },
      {
        "directory": "mc-26_2",
        "min_format": [88, 0],
        "max_format": [88, 0]
      }
    ]
  },

  "catharsis:pack/v1": {
    "id": "skyblock_legacy",
    "version": "1.0.3",
    "dependencies": {"catharsis": ">=1.0.0-beta.5"},
    "config": [
      {
        "type": "tab",
        "title": "SkyBlock Legacy",
        "options": [
          {
            "type": "information",
            "title": "Legacy Textures",
            "description": [{"text":"The original Hypixel SkyBlock textures, which are a mix of vanilla Minecraft items and custom player heads.", "color":"gray"}]
          },
          {
            "type": "separator",
            "title": "Vanilla Colors",
            "description": [{"text":"Use the vanilla Minecraft text colors instead of Hypixel's.", "color":"gray"}]
          },
          {
            "type": "boolean",
            "id": "skyblock_legacy:vanilla_tooltips",
            "title": "Vanilla Tooltips",
            "description": [{"text":"Use the vanilla Minecraft tooltips instead of Hypixel's.", "color":"gray"}],
            "default": false
          },
          {
            "type": "boolean",
            "id": "skyblock_legacy:no_shortbow_drawback",
            "title": "Remove Shortbow Drawback",
            "description": [{"text":"Remove the drawback animation on shortbows.", "color":"gray"}],
            "default": false
          }
        ]
      }
    ]
  },

  "fabric:overlays": {
    "entries": [
      {
        "directory": "vanilla_tooltips",
        "condition": {
          "condition": "catharsis:config",
          "pack": "skyblock_legacy",
          "id": "skyblock_legacy:vanilla_tooltips"
        }
      },
      {
        "directory": "no_shortbow_drawback",
        "condition": {
          "condition": "catharsis:config",
          "pack": "skyblock_legacy",
          "id": "skyblock_legacy:no_shortbow_drawback"
        }
      }
    ]
  },

  "meta": {
    "version": ["v1.0.3", "mc:1.21.11+"],
    "discord": "https://discord.gg/M7HqWKxDxS"
  }
}